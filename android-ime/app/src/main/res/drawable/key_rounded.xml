<?xml version="1.0" encoding="utf-8"?>
<!--
  White rounded rectangle for normal character keys.
  Includes a pressed state so keys give visual feedback.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/key_pressed_background" />
            <corners android:radius="6dp" />
            <stroke android:width="0dp" android:color="#00000000" />
        </shape>
    </item>

    <item>
        <layer-list>
            <!-- Shadow / elevation look -->
            <item android:top="0dp" android:bottom="-1dp">
                <shape android:shape="rectangle">
                    <solid android:color="#22000000" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
            <!-- Key face -->
            <item android:bottom="1dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/key_background" />
                    <corners android:radius="6dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
